server:
  port: 8080

spring:
  application:
    name: seckill-mall
  mvc:
    pathmatch:
      matching-strategy: ANT_PATH_MATCHER
  # 数据源配置
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/seckill_mall?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
    username: root
    password: ${DB_PASSWORD:your_password_here}

  # Redis 配置
  redis:
    host: ${REDIS_HOST:localhost}
    port: 6379
    password: ${REDIS_PASSWORD:}
    database: 0
    lettuce:
      pool:
        max-active: 20
        max-idle: 10
        min-idle: 5
        max-wait: 3000ms

  # 文件上传限制
  servlet:
    multipart:
      max-file-size: 5MB
      max-request-size: 5MB

  # RabbitMQ 配置
  rabbitmq:
    host: ${RABBITMQ_HOST:localhost}
    port: 5672
    username: ${RABBITMQ_USERNAME:guest}
    password: ${RABBITMQ_PASSWORD:guest}
    virtual-host: /
    listener:
      simple:
        acknowledge-mode: manual
        prefetch: 1

# MyBatis-Plus 配置
mybatis-plus:
  configuration:
    map-underscore-to-camel-case: true
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl
  global-config:
    db-config:
      id-type: auto

# JWT 配置
jwt:
  secret: ${JWT_SECRET:your-jwt-secret-key-must-be-at-least-256-bits-long}
  expiration: 86400000  # 24小时

# springdoc-openapi 配置
springdoc:
  swagger-ui:
    path: /swagger-ui.html

# Actuator 监控配置
management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics,prometheus
  endpoint:
    health:
      show-details: always

# 文件上传配置
file:
  upload-dir: ./uploads
  base-url: ${BASE_URL:http://localhost:8080}/uploads

# 阿里云百练 AI 助手配置
ai:
  enabled: true
  api-key: ${AI_API_KEY:your-api-key-here}
  model: qwen-turbo
  max-tokens: 1500
  system-prompt: |
    你是秒杀商城的AI购物助手，名叫"小秒"。你的职责是：
    1. 帮助用户了解商品信息、推荐商品
    2. 解答秒杀活动相关问题（如何参与、规则说明等）
    3. 协助用户处理订单、购物车、优惠券等问题
    4. 提供购物流程指导
    5. 回答常见问题（配送、退换货、支付等）

    回复要求：
    - 语气友好、亲切，像一个专业的导购员
    - 回答简洁明了，避免过长
    - 涉及具体商品时，可以建议用户查看商品列表
    - 不确定的信息不要编造，诚实告知用户
